# Notion internal integration token (notion.so/my-integrations)
NOTION_TOKEN=secret_xxx

# Anthropic API key (same account as MedTracker)
ANTHROPIC_API_KEY=sk-ant-xxx

# Twilio (same as MedTracker)
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886  # use MedTracker's production sender (shared 24h window)
MY_WHATSAPP_TO=whatsapp:+46XXXXXXXXX

# Set to 1 only for a manual test run (sends digest regardless of weekday)
# FORCE_DIGEST=1

# Approved WhatsApp content template SID (Twilio Content Template Builder)
# Template body: "🧠 Second Brain: {{1}}
#
# Open: {{2}}"  — category: Utility
TWILIO_CONTENT_SID=HXxxx
